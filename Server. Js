const express = require("express");
const bodyParser = require("body-parser");
const axios = require("axios");

const app = express();
app.use(bodyParser.json());

// 🔴 እዚህ TOKEN አስገባ
const TOKEN = "8744718432:AAHDKfPibI_Ne9LpYO290KfM2lJ-O-VkuxQ";
const TELEGRAM_API = `https://api.telegram.org/bot${TOKEN}`;

let lastNumber = 0;

// ✅ Telegram webhook
app.post("/update", async (req, res) => {
    console.log("📩 Update:", req.body); // debug

    const message = req.body.message;

    if (message) {
        const chatId = message.chat.id;
        const text = message.text;

        // 🎰 START
        if (text === "/start") {
            await axios.post(`${TELEGRAM_API}/sendMessage`, {
                chat_id: chatId,
                text: "🎰 Welcome to Shento Bingo!\nSend a number (1-75)"
            });
        }

        // 🔢 NUMBER
        else if (!isNaN(text)) {
            lastNumber = Number(text);

            await axios.post(`${TELEGRAM_API}/sendMessage`, {
                chat_id: chatId,
                text: `✅ Number received: ${lastNumber}`
            });
        }
    }

    res.sendStatus(200);
});

// 🌐 Website API
app.get("/number", (req, res) => {
    res.json({ number: lastNumber });
});

// 🟢 ROOT (important for Render)
app.get("/", (req, res) => {
    res.send("✅ Server is running");
});

// 🔥 IMPORTANT FIX (PORT)
const PORT = process.env.PORT || 3000;
app.listen(PORT, () => {
    console.log("🚀 Server running on port " + PORT);
});
